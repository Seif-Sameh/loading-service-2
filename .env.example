# Copy to .env and adjust.
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8009
# Path to trained PPO+Transformer checkpoint (relative to repo root).
RL_WEIGHTS_PATH=models/gopt_v1.pt
# Heightmap resolution in millimetres (lower = more precise, slower).
HEIGHTMAP_RESOLUTION_MM=10
# Max corner-point candidates per step (caps transformer action space).
MAX_EMS_PER_STEP=80
